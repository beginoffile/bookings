{{template "base" .}}


{{define "content"}}

<div class="container">
    <div class="row">
        <div class="col">
            <h1>This is the about page</h1>
            <p>This is a paragraph of text</p>
            <p>No es lo que parece</p>
            <p>This come from the template: {{index .StringMap "text"}}</p>
            <p>
                {{if ne (index .StringMap "remote_ip") ""}}
                    Your remote Ip address is {{index .StringMap "remote_ip"}}
                {{else}}
                    I don't know your ip address yet. Visit the <a ref="/">Home page</a> so I can set it.
                {{end}}
            </p>
        </div>
    </div>
</div>    


{{end}}