{{template "admin" .}}

{{define "page-title"}}
    Reservation
{{end}}


{{define "content"}}
    {{$res := index .Data "reservation"}}
    {{$src := index .StringMap "src"}}
    <div class="col-md-12">
        <p>
            <strong>Arrival:</strong> {{humanDate $res.StartDate}}<br>
            <strong>Deparature:</strong> {{humanDate $res.EndDate}}<br>
            <strong>Room:</strong> {{$res.Room.RoomName}}<br>
        </p>

        <form action="/admin/reservations/{{$src}}/{{$res.ID}}" method = "post" class=""  novalidate>
            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
            

            <div class="form-group mt-3">
                <label for="first_name" class="fw-bold">First Name</label>
                {{with .Form.Errors.Get "first_name"}}
                    <label class="text-danger">{{.}} </label>
                {{end}}
                <input type="text" value="{{$res.FirstName}}" name="first_name" id="first_name" class="form-control {{with .Form.Errors.Get "first_name"}} is-invalid {{end}}" required autocomplete="off" >
            </div>

            <div class="form-group">
                <label for="last_name" class="fw-bold">Last Name</label>
                {{with .Form.Errors.Get "last_name"}}
                <label class="text-danger">{{.}} </label>
                {{end}}
                <input type="text" value="{{$res.LastName}}" name="last_name" id="last_name" class="form-control {{with .Form.Errors.Get "last_name"}} is-invalid {{end}}" required autocomplete="off">
            </div>



            <div class="form-group">
                <label for="email" class="fw-bold">Email</label>
                {{with .Form.Errors.Get "email"}}
                <label class="text-danger">{{.}} </label>
            {{end}}
                <input type="email" value="{{$res.Email}}" name="email" id="email" class="form-control {{with .Form.Errors.Get "email"}} is-invalid {{end}}" required autocomplete="off">
            </div>

            <div class="form-group">
                <label for="phone" class="fw-bold">phone</label>
                {{with .Form.Errors.Get "phone"}}
                <label class="text-danger">{{.}} </label>
                {{end}}
                <input type="text" value="{{$res.Phone}}" name="phone" id="phone" class="form-control {{with .Form.Errors.Get "phone"}} is-invalid {{end}}" required autocomplete="off">
            </div>


            <hr>

            <input type="submit" class="btn btn-primary" value="Save">
            <a href="/admin/reservations-{{$src}}" class="btn btn-warning">Cancel</a>

        </form>

    </div>

{{end}}